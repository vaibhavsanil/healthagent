# LLM Provider configuration: deepseek, gemini, openai, or ollama
DEFAULT_PROVIDER=deepseek

# API keys for frontier LLMs
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Model name overrides (optional)
DEEPSEEK_MODEL=deepseek-chat
# GEMINI_MODEL=gemini-1.5-flash
# OPENAI_MODEL=gpt-4o-mini
# OLLAMA_MODEL=llama3

# Local Ollama endpoint
OLLAMA_HOST=http://localhost:11434

# Database path (optional, will be overwritten by docker-compose)
DATABASE_URL=sqlite:///data/healthcare.db
